{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "declaration": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@axonsdev/hateoas-core": ["packages/hateoas-core/src/index.ts"],
      "@axonsdev/hateoas-siren": ["packages/hateoas-siren/src/index.ts"],
      "@axonsdev/hateoas-fetch": ["packages/hateoas-fetch/src/index.ts"],
      "@axonsdev/hateoas-angular": ["packages/hateoas-angular/src/index.ts"],
      "@axonsdev/hateoas-nestjs": ["packages/hateoas-nestjs/src/index.ts"],
      "@axonsdev/hateoas-nestjs-typeorm": ["packages/hateoas-nestjs-typeorm/src/index.ts"]
    }
  }
}
